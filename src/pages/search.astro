---
import Layout from '../layouts/Layout.astro';

const title = "Search";
const description = "Search the AI Glossary";
---

<Layout title={title} description={description}>
  <div class="max-w-2xl">
    <h1 class="text-4xl font-bold mb-8">Search AI Glossary</h1>

    <div class="mb-8">
      <input
        type="search"
        id="search-input"
        placeholder="Search terms..."
        class="w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded text-white placeholder-slate-500 focus:outline-none focus:border-accent"
      />
    </div>

    <div id="search-results" class="space-y-4">
      <p class="text-slate-400">Start typing to search...</p>
    </div>
  </div>

  <script>
    const searchInput = document.getElementById('search-input');
    const resultsContainer = document.getElementById('search-results');

    searchInput?.addEventListener('input', async (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase();

      if (query.length < 2) {
        resultsContainer!.innerHTML = '<p class="text-slate-400">Start typing to search...</p>';
        return;
      }

      // Placeholder: In production, integrate Pagefind here
      resultsContainer!.innerHTML = '<p class="text-slate-400">Search integration coming soon...</p>';
    });
  </script>
</Layout>

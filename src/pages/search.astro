---
import Layout from '../layouts/Layout.astro';

const title = "Search";
const description = "Search the AI Glossary";
---

<Layout title={title} description={description}>
  <div class="max-w-2xl">
    <h1 class="text-4xl font-bold mb-8">Search AI Glossary</h1>

    <div class="mb-8">
      <input
        type="search"
        id="search-input"
        placeholder="Search terms..."
        class="w-full px-4 py-3 bg-slate-900 border border-slate-700 rounded text-white placeholder-slate-500 focus:outline-none focus:border-accent"
      />
    </div>

    <div id="search-results" class="space-y-4">
      <p class="text-slate-400">Start typing to search...</p>
    </div>
  </div>

  <script>
    const searchInput = document.getElementById('search-input');
    const resultsContainer = document.getElementById('search-results');
    let pagefind = null;

    async function getPagefind() {
      if (!pagefind) {
        pagefind = await import(/* @vite-ignore */ '/pagefind/pagefind.js');
      }
      return pagefind;
    }

    searchInput?.addEventListener('input', async (e) => {
      const query = (e.target).value.toLowerCase();

      if (query.length < 2) {
        resultsContainer.innerHTML = '<p class="text-slate-400">Start typing to search...</p>';
        return;
      }

      resultsContainer.innerHTML = '<p class="text-slate-400">Searching...</p>';

      try {
        const pf = await getPagefind();
        const search = await pf.search(query);

        if (!search.results || search.results.length === 0) {
          resultsContainer.innerHTML = '<p class="text-slate-400">No results found for "' + query + '".</p>';
          return;
        }

        const items = await Promise.all(
          search.results.slice(0, 20).map(async (r) => {
            const data = await r.data();
            return '<a href="' + data.url + '" class="block p-4 bg-slate-900 border border-slate-800 rounded hover:border-accent transition">' +
              '<h3 class="font-semibold text-accent">' + data.title + '</h3>' +
              '<p class="text-sm text-slate-400 mt-1">' + data.excerpt + '</p>' +
            '</a>';
          })
        );

        resultsContainer.innerHTML = '<div class="space-y-4">' + items.join('') + '</div>';
      } catch (err) {
        resultsContainer.innerHTML = '<p class="text-slate-400">Search error. Please try again.</p>';
      }
    });
  </script>
</Layout>

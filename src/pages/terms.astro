---
import Layout from '../layouts/Layout.astro';

const title = "Terms of Service";
const description = "Terms of Service for AI Glossary for Beginners.";
---

<Layout title={title} description={description}>
  <article class="max-w-2xl prose prose-invert">
    <h1 class="text-4xl font-bold mb-8 text-white">Terms of Service</h1>
    <p class="text-slate-300 mb-4"><strong>Last updated:</strong> May 21, 2026</p>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-3">Use of Content</h2>
      <p class="text-slate-300 mb-3">All content on AI Glossary for Beginners is provided for educational and informational purposes only. We strive for accuracy but make no guarantees.</p>
      <p class="text-slate-300 mb-3">You may share and link to our content freely. Reproduction or republication of substantial portions requires attribution.</p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-3">No Professional Advice</h2>
      <p class="text-slate-300 mb-3">The information on this site does not constitute professional, legal, or technical advice. Always consult appropriate professionals for decisions related to AI implementation.</p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-3">Limitation of Liability</h2>
      <p class="text-slate-300 mb-3">AI Glossary for Beginners shall not be held liable for any damages arising from the use of this site or reliance on its content.</p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-3">Changes</h2>
      <p class="text-slate-300 mb-3">We reserve the right to update these terms at any time. Changes will be posted on this page.</p>
    </section>

    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-3">Contact</h2>
      <p class="text-slate-300">For questions about these terms, please <a href="mailto:hello@ai-glossary.example.com" class="text-accent hover:underline">contact us</a>.</p>
    </section>
  </article>
</Layout>

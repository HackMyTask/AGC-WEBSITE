---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const glossaryFiles = import.meta.glob('../../content/glossary/*.md', { eager: true });

  return Object.entries(glossaryFiles).map(([path, file]) => {
    const slug = path.split('/').pop()?.replace('.md', '');
    return {
      params: { slug },
      props: { file }
    };
  });
}

interface Props {
  file: any;
}

const { file } = Astro.props;
const { slug } = Astro.params;

// Parse frontmatter and content
const content = file.default?.toString() || '';
const parts = content.split('---');
const frontmatterText = parts[1] || '';
const body = parts.slice(2).join('---').trim();

// Parse frontmatter
const frontmatter: Record<string, any> = {};
frontmatterText.split('\n').forEach(line => {
  if (line.includes(':')) {
    const [key, ...valueParts] = line.split(':');
    frontmatter[key.trim()] = valueParts.join(':').trim();
  }
});

const title = frontmatter.title || 'Untitled';
const description = frontmatter.description || '';
const keywords = frontmatter.keywords || [];
const cluster = frontmatter.cluster || '';
const relatedTerms = frontmatter.related_terms || [];
---

<Layout title={title} description={description}>
  <article>
    <div class="mb-8">
      <div class="flex items-center gap-2 text-sm text-slate-400 mb-4">
        <a href="/" class="hover:text-accent">Home</a>
        <span>/</span>
        <a href={`/topics/${cluster}`} class="hover:text-accent capitalize">{cluster}</a>
        <span>/</span>
        <span>{title}</span>
      </div>

      <h1 class="text-4xl font-bold mb-4 text-white">{title}</h1>
      <p class="text-lg text-slate-300 mb-6">{description}</p>

      <div class="flex flex-wrap gap-2 mb-6">
        {keywords.map((keyword: string) => (
          <span class="px-3 py-1 bg-slate-900 text-slate-300 text-sm rounded">
            {keyword}
          </span>
        ))}
      </div>

      <div class="text-sm text-slate-400 border-t border-slate-800 pt-4">
        <p>By <span class="text-accent">AI Glossary Team</span></p>
        <p>Published: {frontmatter.created_at}</p>
      </div>
    </div>

    <div class="prose prose-invert max-w-none mb-12">
      <Fragment set:html={body} />
    </div>

    {relatedTerms && relatedTerms.length > 0 && (
      <section class="border-t border-slate-800 pt-8">
        <h2 class="text-2xl font-bold mb-6">Related Terms</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {relatedTerms.map((term: string) => (
            <a href={`/glossary/${term}`} class="p-4 bg-slate-900 border border-slate-800 rounded hover:border-accent transition">
              <p class="text-accent font-semibold">{term}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</Layout>

<style is:global>
  .prose {
    --tw-prose-body: rgb(226 232 240);
    --tw-prose-headings: rgb(248 250 252);
    --tw-prose-links: rgb(14 165 233);
    --tw-prose-code: rgb(226 232 240);
    --tw-prose-pre-bg: rgb(15 23 42);
  }

  .prose h2 {
    @apply text-2xl font-bold mt-8 mb-4;
  }

  .prose h3 {
    @apply text-xl font-semibold mt-6 mb-3;
  }

  .prose p {
    @apply mb-4 leading-relaxed;
  }

  .prose a {
    @apply text-accent hover:underline;
  }

  .prose code {
    @apply bg-slate-900 px-2 py-1 rounded text-sm;
  }

  .prose pre {
    @apply bg-slate-900 p-4 rounded overflow-x-auto;
  }

  .prose ul, .prose ol {
    @apply ml-6 mb-4;
  }

  .prose li {
    @apply mb-2;
  }
</style>

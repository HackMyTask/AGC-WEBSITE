---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const title = "AI Glossary for Beginners";
const description = "AI explained simply for normal humans. Learn AI concepts in plain language.";

const clusters = [
  { id: 'ai-basics', name: 'AI Basics', icon: '🧠' },
  { id: 'llms', name: 'LLMs & Models', icon: '🤖' },
  { id: 'prompt-engineering', name: 'Prompt Engineering', icon: '✍️' },
  { id: 'ai-tools', name: 'AI Tools & Apps', icon: '🛠️' },
  { id: 'ai-agents', name: 'AI Agents', icon: '🕵️' },
  { id: 'ai-infrastructure', name: 'AI Infrastructure', icon: '⚙️' },
];

// Get actual published articles
const allArticles = await getCollection('glossary');
const latestArticles = allArticles.slice(0, 4);
const totalCount = allArticles.length;
---

<Layout title={title} description={description}>
  <section class="mb-16">
    <h1 class="text-5xl font-bold mb-4 text-white">AI Explained Simply</h1>
    <p class="text-xl text-slate-300 mb-8">
      Learn AI concepts in plain language. No jargon. No intimidation. Just clear explanations for normal humans.
    </p>
    <div class="flex gap-4">
      <a href="/search" class="px-6 py-3 bg-accent text-slate-950 font-semibold rounded hover:bg-blue-400 transition">
        Search Terms
      </a>
      {totalCount > 0 && (
        <span class="px-4 py-3 text-slate-400 text-sm self-center">
          {totalCount} terms explained
        </span>
      )}
    </div>
  </section>

  {latestArticles.length > 0 && (
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-8">Latest Articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {latestArticles.map(article => (
          <a href={`/glossary/${article.id}`} class="p-4 bg-slate-900 border border-slate-800 rounded hover:border-accent transition">
            <h3 class="font-semibold text-accent">{article.data.title}</h3>
            <p class="text-sm text-slate-400 mt-1">{article.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mb-16">
    <h2 class="text-2xl font-bold mb-8">Topics</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {clusters.map(cluster => (
        <div class="p-6 bg-slate-900 border border-slate-800 rounded">
          <div class="text-3xl mb-2">{cluster.icon}</div>
          <h3 class="font-semibold text-lg">{cluster.name}</h3>
          <p class="text-sm text-slate-400 mt-2">
            {allArticles.filter(a => a.data.cluster === cluster.id).length} articles
          </p>
        </div>
      ))}
    </div>
  </section>

  {totalCount > 0 && (
    <section>
      <h2 class="text-2xl font-bold mb-8">Browse Alphabetically</h2>
      <div class="flex flex-wrap gap-2">
        {Array.from('ABCDEFGHIJKLMNOPQRSTUVWXYZ').map(letter => {
          const count = allArticles.filter(a => a.data.title.toUpperCase().startsWith(letter)).length;
          return count > 0 ? (
            <span class="px-3 py-2 bg-slate-900 border border-slate-800 rounded text-sm font-medium text-accent">
              {letter} <span class="text-slate-500 text-xs">({count})</span>
            </span>
          ) : (
            <span class="px-3 py-2 bg-slate-900/50 border border-slate-800/50 rounded text-sm font-medium text-slate-600">
              {letter}
            </span>
          );
        })}
      </div>
    </section>
  )}
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const title = "AI Glossary for Beginners";
const description = "AI explained simply for normal humans. Learn AI concepts in plain language.";

const clusters = [
  { id: 'ai-basics', name: 'AI Basics', icon: '🧠' },
  { id: 'llms', name: 'LLMs & Models', icon: '🤖' },
  { id: 'prompt-engineering', name: 'Prompt Engineering', icon: '✍️' },
  { id: 'ai-tools', name: 'AI Tools & Apps', icon: '🛠️' },
  { id: 'ai-agents', name: 'AI Agents', icon: '🕵️' },
  { id: 'ai-infrastructure', name: 'AI Infrastructure', icon: '⚙️' },
];

// Get actual published articles
const allArticles = await getCollection('glossary');
const latestArticles = allArticles.slice(0, 4);
const totalCount = allArticles.length;

// Group articles by first letter for alphabetical browse
const articlesByLetter: Record<string, typeof allArticles> = {};
allArticles.forEach(article => {
  const firstChar = article.data.title.charAt(0).toUpperCase();
  if (!articlesByLetter[firstChar]) articlesByLetter[firstChar] = [];
  articlesByLetter[firstChar].push(article);
});
---

<Layout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "AI Glossary for Beginners",
      "url": "https://ailibrary.site",
      "description": description,
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://ailibrary.site/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />
  </Fragment>
  <section class="mb-16">
    <h1 class="text-5xl font-bold mb-4 text-white">AI Explained Simply</h1>
    <p class="text-xl text-slate-300 mb-8">
      Learn AI concepts in plain language. No jargon. No intimidation. Just clear explanations for normal humans.
    </p>
    <div class="flex gap-4">
      <a href="/search" class="px-6 py-3 bg-accent text-slate-950 font-semibold rounded hover:bg-blue-400 transition">
        Search Terms
      </a>
      {totalCount > 0 && (
        <span class="px-4 py-3 text-slate-400 text-sm self-center">
          {totalCount} terms explained
        </span>
      )}
    </div>
  </section>

  {latestArticles.length > 0 && (
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-8">Latest Articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {latestArticles.map(article => (
          <a href={`/glossary/${article.id}`} class="p-4 bg-slate-900 border border-slate-800 rounded hover:border-accent transition">
            <h3 class="font-semibold text-accent">{article.data.title}</h3>
            <p class="text-sm text-slate-400 mt-1">{article.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mb-16">
    <h2 class="text-2xl font-bold mb-8">Topics</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {clusters.map(cluster => (
        <a href={`/topics/${cluster.id}`} class="p-6 bg-slate-900 border border-slate-800 rounded hover:border-accent transition block">
          <div class="text-3xl mb-2">{cluster.icon}</div>
          <h3 class="font-semibold text-lg">{cluster.name}</h3>
          <p class="text-sm text-slate-400 mt-2">
            {allArticles.filter(a => a.data.cluster === cluster.id).length} articles
          </p>
        </a>
      ))}
    </div>
  </section>

  {totalCount > 0 && (
    <section>
      <h2 class="text-2xl font-bold mb-8">Browse Alphabetically</h2>
      <div class="flex flex-wrap gap-2 mb-8">
        {Array.from('ABCDEFGHIJKLMNOPQRSTUVWXYZ').map(letter => {
          const count = articlesByLetter[letter]?.length || 0;
          return count > 0 ? (
            <a href={`#letter-${letter}`} class="px-3 py-2 bg-slate-900 border border-slate-800 rounded text-sm font-medium text-accent hover:border-accent transition">
              {letter} <span class="text-slate-500 text-xs">({count})</span>
            </a>
          ) : (
            <span class="px-3 py-2 bg-slate-900/50 border border-slate-800/50 rounded text-sm font-medium text-slate-600">
              {letter}
            </span>
          );
        })}
      </div>

      {Object.entries(articlesByLetter).sort(([a], [b]) => a.localeCompare(b)).map(([letter, articles]) => (
        <div id={`letter-${letter}`} class="mb-8">
          <h3 class="text-lg font-bold text-accent mb-3 border-b border-slate-800 pb-2">{letter}</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-2">
            {articles.map(article => (
              <a href={`/glossary/${article.id}`} class="px-3 py-2 text-slate-300 hover:text-accent transition text-sm">
                {article.data.title}
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  )}
</Layout>

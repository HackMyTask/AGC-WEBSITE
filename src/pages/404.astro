---
import Layout from '../layouts/Layout.astro';

const title = "Page Not Found";
const description = "The page you are looking for does not exist.";
---

<Layout title={title} description={description}>
  <div class="text-center py-20">
    <h1 class="text-6xl font-bold text-accent mb-6">404</h1>
    <h2 class="text-2xl font-bold mb-4 text-white">Page Not Found</h2>
    <p class="text-slate-300 mb-8 max-w-md mx-auto">
      The page you are looking for doesn't exist or has been moved.
    </p>
    <div class="flex gap-4 justify-center">
      <a href="/" class="px-6 py-3 bg-accent text-slate-950 font-semibold rounded hover:bg-blue-400 transition">
        Go Home
      </a>
      <a href="/search" class="px-6 py-3 bg-slate-800 text-slate-200 font-semibold rounded hover:bg-slate-700 transition">
        Search
      </a>
    </div>
  </div>
</Layout>

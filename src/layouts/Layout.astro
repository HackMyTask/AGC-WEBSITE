---
interface Props {
  title: string;
  description?: string;
  type?: string;
  ogImage?: string;
}

const { title, description, type = 'website', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const siteName = 'AI Glossary for Beginners';
const fullTitle = `${title} — ${siteName}`;
const metaDescription = description || 'AI explained simply for normal humans. Learn AI concepts in plain language.';
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : new URL('/og-default.svg', Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#020617" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#0ea5e9" />

    <!-- Performance: Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" /></noscript>

    <!-- Performance: Prefetch common navigation targets -->
    <link rel="prefetch" href="/search" />
    <link rel="prefetch" href="/about" />

    <!-- Additional head content from pages -->
    <slot name="head" />
  </head>
  <body class="bg-slate-950 text-slate-100 font-sans">
    <header class="border-b border-slate-800 sticky top-0 z-50 bg-slate-950/95 backdrop-blur">
      <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-accent">AI Glossary</a>
        <div class="flex gap-6">
          <a href="/search" class="text-sm hover:text-accent transition">Search</a>
          <a href="/about" class="text-sm hover:text-accent transition">About</a>
        </div>
      </nav>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-slate-800 mt-20 py-8 text-center text-sm text-slate-400">
      <p>&copy; 2026 AI Glossary Team. All rights reserved.</p>
    </footer>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    padding: 0;
  }
</style>

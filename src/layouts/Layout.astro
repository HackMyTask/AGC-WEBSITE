---
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — AI Glossary for Beginners</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-slate-950 text-slate-100 font-sans">
    <header class="border-b border-slate-800 sticky top-0 z-50 bg-slate-950/95 backdrop-blur">
      <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-accent">AI Glossary</a>
        <div class="flex gap-6">
          <a href="/glossary/a" class="text-sm hover:text-accent transition">Browse</a>
          <a href="/search" class="text-sm hover:text-accent transition">Search</a>
          <a href="/about" class="text-sm hover:text-accent transition">About</a>
        </div>
      </nav>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-slate-800 mt-20 py-8 text-center text-sm text-slate-400">
      <p>&copy; 2026 AI Glossary Team. All rights reserved.</p>
    </footer>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    padding: 0;
  }
</style>

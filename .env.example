AI_PROVIDER=groq

# Single API key (default)
GROQ_API_KEY=your_groq_api_key_here

# Multiple API keys for rotation (comma or pipe separated)
# GROQ_API_KEY=key1,key2,key3
# GROQ_API_KEY=key1|key2|key3

GEMINI_API_KEY=your_gemini_api_key_here

# Multiple Gemini keys for rotation
# GEMINI_API_KEY=key1,key2,key3

DAILY_LIMIT=100
BATCH_SIZE=20

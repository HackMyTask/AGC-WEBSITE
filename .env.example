AI_PROVIDER=groq

# Single API key (default)
GROQ_API_KEY=your_groq_api_key_here

# Multiple API keys for rotation (comma or pipe separated)
# GROQ_API_KEY=key1,key2,key3
# GROQ_API_KEY=key1|key2|key3

GEMINI_API_KEY=your_gemini_api_key_here

# Multiple Gemini keys for rotation
# GEMINI_API_KEY=key1,key2,key3

DAILY_LIMIT=100
BATCH_SIZE=20

# Telegram Notifications (optional)
# Get bot token: https://t.me/BotFather
# Get chat ID: Send message to bot, then: curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# SEO
# Site URL used in canonical tags, sitemap, and OG images (must match astro.config.mjs site)
SITE_URL=https://ailibrary.site
# Base URL for OG images (defaults to SITE_URL/og if not set)
OG_IMAGE_BASE=https://ailibrary.site/og
# Default OG image fallback path (relative to public/)
OG_IMAGE_DEFAULT=/og-default.svg
# Author name used in article schema markup
SITE_AUTHOR="AI Glossary Team"
